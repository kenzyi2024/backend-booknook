# Environment Variables (CRUCIAL: Hides your database password and API keys)
.env

# Node Modules (Hides the massive folder of downloaded packages)
node_modules/

# Mac OS specific system files (Prevents annoying hidden files from uploading)
.DS_Store

# Log files (Ignores error logs generated by npm)
npm-debug.log*
yarn-debug.log*
yarn-error.log*